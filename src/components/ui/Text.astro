---
interface Props {
   small?: boolean;
}

const { small } = Astro.props;

const className = small ? "small-style" : undefined;
---

<p class={className}>
   <slot />
</p>

<style>
   p {
      font-size: 16px;
      font-weight: 500;
      color: var(--text-color);
   }

   p.small-style {
      font-size: 14px;
   }

   @media screen and (min-width: 1280px) {
      p {
         font-size: 18px;
      }

      p.small-style {
         font-size: 16px;
      }
   }
</style>
