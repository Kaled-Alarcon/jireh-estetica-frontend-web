---
import { base } from "astro:config/server";

import Title from "../ui/Title.astro";
import Text from "../ui/Text.astro";
import Button from "../ui/Button.astro";
import VideoPlayer from "../ui/VideoPlayer.astro";
---

<section id="hero">
   <div class="auto-margin">
      <div id="hero-text">
         <Title type="h1">Realza tu belleza, <br /> <span>forja tu futuro</span></Title>
         <Text
            >Descubre nuestros servicios de salón premium y nuestra academia profesional diseñada para formar a las
            proximas especialistas en belleza con rápida salida laboral comprobada.</Text
         >
         <div>
            <a href={`${base}#introduccion-academia`}>
               <Button content="Introducción a la academia" />
            </a>
            <a href={`${base}#servicios-destacados`}>
               <Button content="Servicios populares" secondary />
            </a>
         </div>
      </div>
      <VideoPlayer id="hero-video" videoFile="hero-presentation.mp4" width="100%" height="100%" />
   </div>
</section>

<style>
   #hero {
      height: fit-content;
      padding-block: var(--gap-sections);
      margin-top: 100px;
      display: grid;
      place-items: center;
      background-color: var(--background-color);

      .auto-margin {
         display: flex;
         flex-direction: column;
         gap: var(--gap-sections);

         #hero-text {
            width: 100%;
            height: fit-content;
            display: flex;
            flex-direction: column;
            gap: var(--gap-cards);

            h1 {
               span {
                  color: var(--primary-color);
               }
            }

            div {
               display: flex;
               flex-direction: column;
               gap: var(--gap);
            }
         }
      }
   }

   @media screen and (min-width: 1280px) {
      #hero {
         height: 840px;
         margin-top: 120px;

         .auto-margin {
            height: 712px;
            flex-direction: row;

            #hero-text {
               width: 60%;
               height: 100%;
               justify-content: center;

               p {
                  max-width: 640px;
               }

               div {
                  flex-direction: row;
               }
            }

            #hero-video {
               width: 40% !important;
            }
         }
      }
   }
</style>

