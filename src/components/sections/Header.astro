---
import { base } from "astro:config/server";

import Logo from "../ui/Logo.astro";
import Button from "../ui/Button.astro";
import Title from "../ui/Title.astro";
---

<header id="header">
   <div class="auto-margin">
      <Logo />

      <nav id="header-nav">
         <a href={`${base}/`}>
            <Title type="h6">Inicio</Title>
         </a>

         <a href={`${base}/academia`}>
            <Title type="h6">Academia</Title>
         </a>

         <a href={`${base}/servicios`}>
            <Title type="h6">Servicios</Title>
         </a>

         <a href={`${base}/nosotros`}>
            <Title type="h6">Sobre nosotros</Title>
         </a>

         <a href="">
            <Button content="Contáctanos" />
         </a>
      </nav>

      <button class="header-mobile-menu-button">
         <img class="icon" src="/jireh-estetica-frontend-web/icons/menu.png" alt="open header mobile menu" />
      </button>
   </div>
</header>

<div id="header-mobile-menu">
   <Logo light />

   <div>
      <a href={`${base}/`}>
         <Button content="Inicio" secondary />
      </a>

      <a href={`${base}/academia`}>
         <Button content="Academia" secondary />
      </a>

      <a href={`${base}/servicios`}>
         <Button content="Servicios" secondary />
      </a>

      <a href={`${base}/nosotros`}>
         <Button content="Sobre nosotros" secondary />
      </a>

      <a href="">
         <Button content="Ponte en contacto" />
      </a>
   </div>

   <button class="header-mobile-menu-button">
      <img class="icon" src="/jireh-estetica-frontend-web/icons/cross.png" alt="close header mobile menu" />
   </button>
</div>

<style>
   #header {
      width: 100%;
      height: 100px;
      display: grid;
      place-items: center;

      .auto-margin {
         display: flex;
         justify-content: space-between;
         align-items: center;

         #header-nav {
            display: none;
            align-items: center;
            gap: var(--gap-cards);

            a {
               &:hover {
                  h6 {
                     transition: var(--transitions);
                     color: var(--primary-color);
                  }
               }
            }
         }

         .header-mobile-menu-button {
            height: 20px;
         }
      }
   }

   #header-mobile-menu {
      width: 100%;
      height: 100vh;
      padding: 0 var(--gap);
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: var(--gap-cards);
      position: fixed;
      top: 0;
      left: 100%;
      z-index: 10;
      transition: var(--transitions);
      backdrop-filter: blur(8px);
      background-color: var(--secondary-translucent-color);

      div {
         width: 100%;
         display: flex;
         flex-direction: column;
         gap: var(--gap);

         button {
            /* filter: opacity(95%); */

            span {
               color: var(--background-dark-color);
            }
         }
      }

      .header-mobile-menu-button {
         background-color: transparent;

         img {
            width: 24px;
            height: 24px;
            filter: invert();
         }
      }
   }

   #header-mobile-menu.header-mobile-menu-visible {
      left: 0;
   }

   @media screen and (min-width: 1280px) {
      #header {
         height: 120px;

         .auto-margin {
            #header-nav {
               display: flex;
            }

            .header-mobile-menu-button {
               display: none;
            }
         }
      }
   }
</style>

<script>
   let headerMobileMenuVisible = false;

   const headerMobileMenu = document.getElementById("header-mobile-menu")!;
   const headerMobileMenuButtons = [...document.getElementsByClassName("header-mobile-menu-button")];

   headerMobileMenuButtons.forEach((button) => {
      button.addEventListener("click", () => {
         if (headerMobileMenuVisible) {
            hideHeaderMobileMenu();
         } else {
            showHeaderMobileMenu();
         }
      });
   });

   const showHeaderMobileMenu = () => {
      headerMobileMenuVisible = true;

      headerMobileMenu.classList.add("header-mobile-menu-visible");
   };

   const hideHeaderMobileMenu = () => {
      headerMobileMenuVisible = false;

      headerMobileMenu.classList.remove("header-mobile-menu-visible");
   };
</script>
