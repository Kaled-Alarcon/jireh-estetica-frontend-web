---
import Title from "../ui/Title.astro";
import OurCoursesCard from "../cards/OurCoursesCard.astro";
---

<div id="our-courses">
   <div class="auto-margin">
      <div id="our-courses-head">
         <Title type="h2">Nuestros cursos</Title>
      </div>
      <div id="our-courses-cards">
         <OurCoursesCard
            title="Nombre del curso"
            instructorName="Maria Lopez"
            description="Descripción breve del curso. Que se aprenderá y quien lo imparte."
         />
         <OurCoursesCard
            title="Nombre del curso"
            instructorName="Maria Lopez"
            description="Descripción breve del curso. Que se aprenderá y quien lo imparte."
         />
         <OurCoursesCard
            title="Nombre del curso"
            instructorName="Maria Lopez"
            description="Descripción breve del curso. Que se aprenderá y quien lo imparte."
         />
         <OurCoursesCard
            title="Nombre del curso"
            instructorName="Maria Lopez"
            description="Descripción breve del curso. Que se aprenderá y quien lo imparte."
         />
         <OurCoursesCard
            title="Nombre del curso"
            instructorName="Maria Lopez"
            description="Descripción breve del curso. Que se aprenderá y quien lo imparte."
         />
         <OurCoursesCard
            title="Nombre del curso"
            instructorName="Maria Lopez"
            description="Descripción breve del curso. Que se aprenderá y quien lo imparte."
         />
      </div>
   </div>
</div>

<style>
   #our-courses {
      height: fit-content;
      padding-block: var(--gap-sections);
      display: flex;
      justify-content: center;
      align-items: center;
      background-color: var(--background-dark-color);

      .auto-margin {
         display: flex;
         flex-direction: column;
         gap: var(--gap-sections);

         #our-courses-cards {
            display: grid;
            grid-template-rows: repeat(auto, 1fr);
            grid-template-columns: repeat(1, 1fr);
            gap: var(--gap-cards);
         }
      }
   }

   @media screen and (min-width: 1280px) {
      #our-courses {
         .auto-margin {
            #our-courses-head {
               h2 {
                  text-align: center;
               }
            }

            #our-courses-cards {
               grid-template-columns: repeat(3, 1fr);
            }
         }
      }
   }
</style>
