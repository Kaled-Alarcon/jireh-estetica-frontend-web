---
import { base } from "astro:config/server";

import Title from "../ui/Title.astro";
import Text from "../ui/Text.astro";

interface Props {
   title: string;
   emphasisTitle?: string;
   description: string;
   imageFile: string;
}

const { title, emphasisTitle, description, imageFile } = Astro.props;

const imageUrl = `${base}images/${imageFile}`;
---

<section id="minimal-hero">
   <div class="auto-margin">
      <div id="minimal-hero-text">
         <Title type="h1">{title} {emphasisTitle && <span>{emphasisTitle}</span>}</Title>
         <Text>{description}</Text>
      </div>
      <div id="minimal-hero-image" style={`background-image: url(${imageUrl});`}></div>
   </div>

   <style>
      #minimal-hero {
         height: fit-content;
         padding-block: var(--gap-sections);
         margin-top: 100px;
         display: flex;
         justify-content: center;
         align-items: center;
         background-color: var(--background-dark-color);

         .auto-margin {
            display: flex;
            flex-direction: column;
            align-items: stretch;
            gap: var(--gap-sections);

            #minimal-hero-text {
               display: flex;
               flex-direction: column;
               gap: var(--gap);

               h1 {
                  span {
                     color: var(--primary-color);
                  }
               }
            }

            #minimal-hero-image {
               height: 400px;
               border-radius: var(--rounded-base);
               background-size: cover;
               background-position: center;
               background-repeat: no-repeat;
            }
         }
      }

      @media screen and (min-width: 1280px) {
         #minimal-hero {
            margin-top: 120px;

            .auto-margin {
               flex-direction: row;

               #minimal-hero-text {
                  width: 50%;
                  justify-content: center;
                  gap: var(--gap-cards);
               }

               #minimal-hero-image {
                  width: 50%;
               }
            }
         }
      }
   </style>
</section>
