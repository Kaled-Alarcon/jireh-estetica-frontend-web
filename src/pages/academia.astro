---
import MainLayout from "../layouts/MainLayout.astro";

import MinimalHero from "../components/sections/MinimalHero.astro";
import YourInstructors from "../components/sections/YourInstructors.astro";
import OurCourses from "../components/sections/OurCourses.astro";
import Reviews from "../components/sections/Reviews.astro";
import Footer from "../components/sections/Footer.astro";
---

<MainLayout title="Cursos e instructores">
   <MinimalHero
      title="Transforma tu pasión en "
      emphasisTitle="profesión"
      description="Con la academia de Jireh Estética podrás acceder a conocimiento de alta utilidad en el mercado laboral actual. Nosotros te formaremos desde las bases hasta que seas experto/a."
      imageFile="our-origin-image.jpeg"
   />
   <YourInstructors />
   <OurCourses />
   <Reviews />
   <Footer />
</MainLayout>

<style is:global>
   body {
      #reviews {
         background-color: var(--background-color) !important;

         .auto-margin {
            #reviews-cards-container {
               .review-card {
                  background-color: var(--background-dark-color) !important;
               }
            }
         }
      }
   }
</style>
